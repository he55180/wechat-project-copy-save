# Git忽略文件

# 环境变量（包含敏感信息）
.env
.env.local
.env.*.local

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# 虚拟环境
venv/
.venv/
env/
ENV/

# 输出目录（可选择性保留）
output/*.json
output/raw/

# IDE配置
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 日志
*.log
logs/

# 排版管线临时文件
*_escaped.md
*_temp.docx
output/
!output/latest_report.md
