{
    "name": "hse-news-automation",
    "displayName": "HSE资讯自动化系统",
    "version": "1.0.0",
    "description": "每日自动抓取、AI筛选、邮件推送安环管理热文",
    "author": "HSE Team",
    "license": "MIT",
    "keywords": [
        "HSE",
        "安全管理",
        "环境保护",
        "施工管理",
        "自动化",
        "Gemini AI"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/YOUR_USERNAME/hse-news-automation.git"
    },
    "config": {
        "python_version": "3.11",
        "schedule": "0 1 * * *",
        "schedule_description": "每天北京时间09:00运行"
    },
    "secrets_required": [
        {
            "name": "GEMINI_API_KEY",
            "description": "Google AI Studio API密钥",
            "url": "https://aistudio.google.com/apikey"
        },
        {
            "name": "MAIL_USERNAME",
            "description": "Gmail邮箱地址"
        },
        {
            "name": "MAIL_PASSWORD",
            "description": "Gmail应用专用密码",
            "url": "https://myaccount.google.com/apppasswords"
        }
    ]
}
